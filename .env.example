BOT_TOKEN=
TG_ADMIN_USER_ID=

XBOARD_BASE_URL=https://your-xboard.example.com
XBOARD_ADMIN_PATH=admin

# Recommended: use the real XBoard admin login token.
# If your XBoard admin API uses Bearer auth:
XBOARD_AUTH_TYPE=bearer
XBOARD_AUTH_TOKEN=

# If Bearer auth does not work, use cookie auth instead:
# XBOARD_AUTH_TYPE=cookie
# XBOARD_COOKIE=

# Optional extra secret header for custom deployments. Leave empty unless your XBoard has one.
XBOARD_API_SECRET=

BOT_WEBHOOK_SECRET=
BOT_PUBLIC_URL=
BOT_PORT=3000
DATABASE_PATH=/data/ticket-bot.sqlite
TIMEZONE=Asia/Shanghai
POLL_INTERVAL_SECONDS=30

# Pending ticket stale reminders use Beijing time via TIMEZONE=Asia/Shanghai.
STALE_TICKET_FIRST_REMIND_MINUTES=1
STALE_TICKET_REPEAT_REMIND_MINUTES=1
STALE_TICKET_NIGHT_START_HOUR=0
STALE_TICKET_NIGHT_END_HOUR=8
STALE_TICKET_NIGHT_REPEAT_MINUTES=60

# XBoard route configuration. Override these if your XBoard version or admin path differs.
XBOARD_TICKET_FETCH_PATH=/api/v2/{admin_path}/ticket/fetch
XBOARD_TICKET_DETAIL_PATH=/api/v2/{admin_path}/ticket/fetch
XBOARD_TICKET_REPLY_PATH=/api/v2/{admin_path}/ticket/reply
XBOARD_TICKET_CLOSE_PATH=/api/v2/{admin_path}/ticket/close

# HTTP method overrides.
XBOARD_TICKET_FETCH_METHOD=GET
XBOARD_TICKET_DETAIL_METHOD=GET
XBOARD_TICKET_REPLY_METHOD=POST
XBOARD_TICKET_CLOSE_METHOD=POST

# Optional auth/header tuning for custom deployments.
XBOARD_AUTH_HEADER=Authorization
XBOARD_AUTH_SCHEME=Bearer
XBOARD_API_SECRET_HEADER=X-API-Secret
